# ─────────────────────────────────────────────
#  Memeshift Invoice Manager — Environment Config
#  Copy this to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# App
SITE_URL=https://invoices.your-website.com

# Login credentials
# Generate APP_PASSWORD_HASH by running: php setup/generate-password.php
APP_USERNAME=admin
APP_PASSWORD_HASH=

# Database (SiteGround: find these in cPanel > MySQL Databases)
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# ─────────────────────────────────────────────
#  Your Freelancer Details (appear on all PDFs)
#  Fill these in when ready.
# ─────────────────────────────────────────────
FREELANCER_NAME=Your Full Name
FREELANCER_COMPANY=Your Company / Trade Name
FREELANCER_ADDRESS_LINE1=Street Address
FREELANCER_ADDRESS_LINE2=Postcode, City, Country
FREELANCER_EMAIL=hello@yourdomain.com
FREELANCER_PHONE=+49 000 000 0000
FREELANCER_WEBSITE=www.yourdomain.com
FREELANCER_BANK_NAME=Your Bank Name
FREELANCER_IBAN=DE00 0000 0000 0000 0000 00
FREELANCER_BIC=XXXXXXXX
